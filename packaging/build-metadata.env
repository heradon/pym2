# Shared packaging metadata for build scripts.
# This file is sourced by scripts/build-deb.sh and scripts/build-rpm.sh.

# Debian control field
PYM2_MAINTAINER="Ralf Matthes <maintainer@example.com>"

# RPM spec field
PYM2_PACKAGER="Ralf Matthes <maintainer@example.com>"

# Common descriptive fields
PYM2_DESCRIPTION_SHORT="Linux process manager for Python projects (PM2-like)"
PYM2_DESCRIPTION_LONG="Single-binary process supervisor for Python venv + uvicorn apps."
PYM2_SUMMARY="Linux process manager for Python projects (PM2-like)"

# Optional project URL used in RPM spec
PYM2_PROJECT_URL="https://github.com/heradon/pym2"
